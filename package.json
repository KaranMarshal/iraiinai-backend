{
  "name": "iraiinai-backend",
  "version": "1.0.0",
  "description": "Backend API server for IraiInai AI-powered Matrimony mobile application",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'",
    "test:auth": "ts-node src/utils/testAuth.ts",
    "test:interest": "ts-node src/utils/testInterest.ts",
    "test:dashboard": "ts-node src/utils/testDashboard.ts",
    "test:boost": "ts-node src/utils/testBoost.ts",
    "test:matchmaking": "ts-node src/utils/testMatchmaking.ts",
    "test:chat": "ts-node src/utils/testChat.ts",
    "test:payment": "ts-node src/utils/testPayment.ts",
    "test:premium": "ts-node src/utils/testPremiumFeatures.ts",
    "test:referrals": "ts-node src/utils/testReferrals.ts",
    "kill-port": "powershell -Command \"Stop-Process -Id (Get-NetTCPConnection -LocalPort 5000 -ErrorAction SilentlyContinue).OwningProcess -Force -ErrorAction SilentlyContinue\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.4",
    "@types/nodemailer": "^8.0.1",
    "agora-access-token": "^2.0.4",
    "agora-token": "^2.0.5",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^14.0.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jimp": "^1.6.1",
    "joi": "^17.13.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.4.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^9.0.1",
    "pdfkit": "^0.19.1",
    "razorpay": "^2.9.4",
    "twilio": "^6.0.2",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-mongo-sanitize": "^1.3.2",
    "@types/express-rate-limit": "^5.1.3",
    "@types/hpp": "^0.2.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.12.12",
    "@types/node-cache": "^4.1.3",
    "@types/pdfkit": "^0.17.6",
    "@types/socket.io": "^3.0.1",
    "prettier": "^3.2.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "private": true
}
