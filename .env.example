# App Server configuration
PORT=5000
NODE_ENV=development

# Database configuration
MONGO_URI=mongodb://admin:secretpassword@localhost:27017/iraiinai?authSource=admin

# Firebase Service Account Credentials (base64 encoded JSON string or local path to serviceAccountKey.json)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Razorpay credentials
RAZORPAY_KEY_ID=rzp_test_YourKeyIdHere
RAZORPAY_KEY_SECRET=YourRazorpaySecretHere
RAZORPAY_WEBHOOK_SECRET=YourWebhookSecretHere

# Google Gemini API key (for matchmaking and compatability computing)
GEMINI_API_KEY=YourGeminiApiKeyHere

# JWT secret key for auxiliary auth token generation
JWT_SECRET=your_super_secret_jwt_key_here
